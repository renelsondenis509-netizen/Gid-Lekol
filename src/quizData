    { q: "Le pH d'une solution de NaOH à 0,01 mol/L est :", choices: ["2", "7", "12", "14"], answer: 2, note: "NaOH est une base forte : [OH⁻]=0,01=10⁻², pOH=2, pH=14-2=12." },
    { q: "La réaction de précipitation produit :", choices: ["Un gaz", "Un solide insoluble (précipité)", "Un liquide", "Un ion"], answer: 1, note: "Précipitation : réaction entre ions en solution formant un solide insoluble." },
    { q: "La formule de l'eau est :", choices: ["H₂O₂", "H₂O", "HO", "H₃O"], answer: 1, note: "Eau : H₂O (molécule coudée, polaire, solvant universel)." },
    { q: "Les acides gras saturés n'ont :", choices: ["Aucune liaison C-C", "Pas de doubles liaisons C=C", "Que des doubles liaisons", "Des liaisons triples"], answer: 1, note: "Acides gras saturés : chaîne carbonée sans double liaison (ex: acide palmitique, stéarique)." },
    { q: "L'ADN est différent de l'ARN car l'ADN contient :", choices: ["L'uracile au lieu de la thymine", "La thymine au lieu de l'uracile et le désoxyribose au lieu du ribose", "Le ribose au lieu du désoxyribose", "Des acides aminés"], answer: 1, note: "ADN : thymine + désoxyribose. ARN : uracile + ribose." },
    { q: "Le catalyseur biologique est appelé :", choices: ["Anticorps", "Enzyme", "Hormone", "Vitamine"], answer: 1, note: "Les enzymes sont les catalyseurs biologiques qui accélèrent les réactions biochimiques." },
    { q: "Le nombre d'électrons dans la couche K est au maximum :", choices: ["2", "8", "18", "32"], answer: 0, note: "La couche K (n=1) peut contenir au maximum 2 électrons." },
    { q: "Le nombre d'électrons dans la couche L est au maximum :", choices: ["2", "8", "18", "32"], answer: 1, note: "La couche L (n=2) peut contenir au maximum 8 électrons." },
    { q: "Le nombre d'électrons dans la couche M est au maximum :", choices: ["2", "8", "18", "32"], answer: 2, note: "La couche M (n=3) peut contenir au maximum 18 électrons." },
    { q: "La formule de l'oxyde de calcium (chaux vive) est :", choices: ["CaO", "Ca(OH)₂", "CaCO₃", "CaCl₂"], answer: 0, note: "Chaux vive : CaO (oxyde de calcium). CaO + H₂O → Ca(OH)₂ (chaux éteinte)." },
    { q: "La formule du carbonate de calcium (calcaire) est :", choices: ["CaO", "Ca(OH)₂", "CaCO₃", "CaCl₂"], answer: 2, note: "Calcaire : CaCO₃ (calcium carbonique, constituant des coquilles, du marbre)." },
    { q: "La décomposition thermique du CaCO₃ donne :", choices: ["CaO + CO₂", "Ca + CO₃", "CaO + O₂", "Ca(OH)₂ + CO"], answer: 0, note: "Calcination : CaCO₃ → CaO + CO₂ (réaction utilisée dans les fours à chaux)." },
    { q: "La formule de l'acide acétique (vinaigre) est :", choices: ["CH₃OH", "CH₃COOH", "C₂H₅OH", "HCOOH"], answer: 1, note: "Acide acétique (éthanoïque) : CH₃COOH — composant principal du vinaigre." },
    { q: "L'acide formique (méthanoïque) a pour formule :", choices: ["HCOOH", "CH₃COOH", "C₂H₅COOH", "C₃H₇COOH"], answer: 0, note: "Acide formique : HCOOH (le plus simple des acides carboxyliques, présent dans les fourmis)." },
    { q: "Un indicateur coloré change de couleur selon :", choices: ["La température", "Le pH de la solution", "La concentration en sel", "La pression"], answer: 1, note: "Les indicateurs colorés (BBT, phénolphtaléine, tournesol) changent de couleur selon le pH." },
    { q: "La phénolphtaléine est :", choices: ["Rouge en milieu acide et incolore en milieu basique", "Incolore en milieu acide et rose en milieu basique", "Bleue en milieu acide", "Jaune en milieu neutre"], answer: 1, note: "Phénolphtaléine : incolore si pH < 8,2 ; rose à fuchsia si pH > 8,2." },
    { q: "Le bleu de bromothymol (BBT) est :", choices: ["Jaune en milieu acide, vert en milieu neutre, bleu en milieu basique", "Bleu en milieu acide", "Rouge en milieu basique", "Incolore partout"], answer: 0, note: "BBT : jaune (acide) / vert (neutre) / bleu (basique)." },
    { q: "La formule du sulfate de cuivre anhydre est :", choices: ["CuSO₄", "CuSO₄·5H₂O", "Cu₂SO₄", "CuS"], answer: 0, note: "Sulfate de cuivre anhydre : CuSO₄ (poudre blanche). Hydraté : CuSO₄·5H₂O (cristaux bleus)." },
    { q: "La formule du dioxyde de soufre est :", choices: ["SO₃", "SO₂", "S₂O", "SO"], answer: 1, note: "Dioxyde de soufre : SO₂ (gaz polluant émis lors de la combustion du soufre)." },
    { q: "Le fer se corrode (rouille) en présence de :", choices: ["CO₂ uniquement", "O₂ et H₂O (dioxygène et eau)", "N₂", "Lumière uniquement"], answer: 1, note: "La corrosion (rouille) du fer : 4Fe + 3O₂ + 6H₂O → 4Fe(OH)₃ → Fe₂O₃·nH₂O." },
    { q: "La formule de l'acide phosphorique est :", choices: ["HCl", "H₂SO₄", "H₃PO₄", "HNO₃"], answer: 2, note: "Acide phosphorique : H₃PO₄ (triprotique, utilisé dans les engrais et boissons gazeuses)." },
    { q: "Un sel est formé par :", choices: ["Deux acides", "Un acide et une base", "Deux bases", "Un métal et une base"], answer: 1, note: "Un sel = produit de la neutralisation d'un acide par une base (ex: NaCl = HCl + NaOH)." },
    { q: "La formule de la soude caustique est :", choices: ["H₂SO₄", "NaOH", "Ca(OH)₂", "NH₃"], answer: 1, note: "Soude caustique = hydroxyde de sodium NaOH (base forte, très corrosive)." },
    { q: "L'unité de concentration molaire est :", choices: ["g/L", "mol/L", "g/mol", "L/mol"], answer: 1, note: "La concentration molaire C se mesure en mol/L (molarité)." },
  ],
  "Philosophie": [
    { q: "Le syllogisme est composé de :", choices: ["Une prémisse et une conclusion", "Deux prémisses et une conclusion", "Trois prémisses", "Une hypothèse et une thèse"], answer: 1, note: "Syllogisme : P1 + P2 → Conclusion." },
    { q: "Pour Descartes, le fondement indubitable est :", choices: ["L'expérience sensible", "La révélation divine", "Le cogito 'Je pense donc je suis'", "L'autorité des anciens"], answer: 2, note: "Cogito ergo sum (Méditations, 1641)." },
    { q: "La théorie du contrat social de Rousseau affirme que :", choices: ["L'État est naturel", "La société est fondée sur un accord pour garantir la liberté", "Le roi a un droit divin", "La guerre est naturelle"], answer: 1, note: "Du Contrat Social (1762) : les hommes aliènent leur liberté à la volonté générale." },
    { q: "L'impératif catégorique de Kant signifie :", choices: ["Agir selon son intérêt", "Agir selon des maximes universalisables", "Obéir aux lois de l'État", "Suivre ses émotions"], answer: 1, note: "Kant : 'Agis seulement selon la maxime que tu pourrais vouloir voir devenir une loi universelle'." },
    { q: "Anténor Firmin est l'auteur de :", choices: ["Gouverneurs de la Rosée", "De l'égalité des races humaines (1885)", "Ainsi parla Zarathoustra", "L'Être et le Néant"], answer: 1, note: "Firmin (1850-1911) — précurseur de la négritude haïtienne." },
    { q: "L'existentialisme de Sartre se résume par :", choices: ["L'essence précède l'existence", "L'existence précède l'essence", "L'essence et l'existence coexistent", "L'essence est indépendante"], answer: 1, note: "Sartre : l'homme existe d'abord, puis se définit." },
    { q: "La dialectique de Hegel suit le schéma :", choices: ["Hypothèse → Vérification", "Thèse → Antithèse → Synthèse", "Observation → Loi", "Intuition → Déduction"], answer: 1, note: "Dialectique hégélienne : thèse + antithèse → dépassement (synthèse)." },
    { q: "L'allégorie de la caverne de Platon représente :", choices: ["La puissance de l'État", "L'ignorance humaine et le chemin vers la vérité", "La supériorité des sens", "Le bonheur matériel"], answer: 1, note: "République VII : les prisonniers prennent des ombres pour la réalité." },
    { q: "Hobbes décrit l'état de nature comme :", choices: ["Un paradis de liberté", "Une guerre de tous contre tous", "Un état de coopération", "Une communauté harmonieuse"], answer: 1, note: "Léviathan (1651) : sans État, la vie est 'solitaire, pauvre, méchante, brutale et courte'." },
    { q: "La logique formelle distingue vrai/faux selon :", choices: ["Le principe de causalité", "Le principe de bivalence", "Le principe de relativité", "Le principe de plaisir"], answer: 1, note: "Logique classique (Aristote) : toute proposition est soit vraie, soit fausse." },
    { q: "Socrate utilise la méthode :", choices: ["Déductive pure", "Maïeutique (accouchement des idées par questionnement)", "Empirique", "Mathématique"], answer: 1, note: "La maïeutique socratique : amener l'interlocuteur à accoucher de la vérité par le dialogue." },
    { q: "Platon croit que la connaissance vraie porte sur :", choices: ["Le monde sensible", "Le monde des Idées (formes éternelles)", "Les perceptions sensorielles", "L'opinion du peuple"], answer: 1, note: "Platon : la vraie connaissance = connaissance des Idées éternelles." },
    { q: "L'éthique des vertus d'Aristote cherche :", choices: ["La maximisation du plaisir", "L'eudémonie (bonheur) par les vertus", "L'obéissance aux dieux", "La connaissance pure"], answer: 1, note: "Aristote : la vie bonne = eudémonie, atteinte en développant les vertus." },
    { q: "L'épicurisme enseigne que le bonheur est :", choices: ["Dans la richesse", "Dans l'ataraxie (absence de trouble) et l'aponie", "Dans la gloire", "Dans le sacrifice"], answer: 1, note: "Épicure : bonheur = ataraxie (tranquillité) + aponie (absence de douleur physique)." },
    { q: "Le stoïcisme enseigne que le bonheur est :", choices: ["Dans les plaisirs", "Dans la vertu et l'acceptation de ce qu'on ne contrôle pas", "Dans la richesse", "Dans la fuite du monde"], answer: 1, note: "Stoïcisme : bonheur = vivre selon la raison et accepter le destin." },
    { q: "Nietzsche proclame :", choices: ["'L'homme est un animal politique'", "'Dieu est mort' et propose le Surhomme", "'Je pense donc je suis'", "'Le bonheur est dans la vertu'"], answer: 1, note: "Nietzsche (Gai Savoir, 1882) : 'Dieu est mort' — critique des valeurs chrétiennes." },
    { q: "L'utilitarisme de Bentham et Mill cherche :", choices: ["Le devoir moral absolu", "Le plus grand bonheur pour le plus grand nombre", "La pureté de l'intention", "L'épanouissement personnel"], answer: 1, note: "Utilitarisme : la bonne action maximise le bien-être du plus grand nombre." },
    { q: "Le matérialisme dialectique de Marx est fondé sur :", choices: ["Les idées comme moteur de l'histoire", "Les conditions économiques et matérielles", "La religion", "La volonté individuelle"], answer: 1, note: "Marx : l'infrastructure économique détermine la superstructure idéologique." },
    { q: "Le positivisme d'Auguste Comte dit que la connaissance valide est :", choices: ["Théologique", "Métaphysique", "Scientifique (positive)", "Religieuse"], answer: 2, note: "Comte (loi des 3 états) : stade théologique → métaphysique → positif (scientifique)." },
    { q: "Le pragmatisme américain juge la vérité d'une idée à :", choices: ["Sa beauté", "Son utilité pratique et ses conséquences", "Son ancienneté", "Sa cohérence interne"], answer: 1, note: "Pragmatisme : une idée est vraie si elle est utile, si elle 'fonctionne' dans la pratique." },
    { q: "Heidegger s'interroge sur :", choices: ["La valeur de la démocratie", "Le sens de l'Être (question ontologique)", "La structure du langage", "Les lois de la physique"], answer: 1, note: "Heidegger (Être et Temps, 1927) : la question fondamentale est 'Qu'est-ce que l'Être ?'." },
    { q: "Le dualisme de Descartes sépare :", choices: ["Le bien et le mal", "Le corps (res extensa) et l'esprit (res cogitans)", "La science et la religion", "La raison et l'émotion"], answer: 1, note: "Dualisme cartésien : corps (étendue, matière) + esprit (pensée, immatériel)." },
    { q: "L'empirisme (Locke, Hume) affirme que la connaissance provient de :", choices: ["La raison pure", "L'expérience sensible", "La révélation divine", "La raison innée"], answer: 1, note: "Empirisme : toute connaissance vient de l'expérience et des sens." },
    { q: "Le rationalisme (Descartes, Spinoza) affirme que la connaissance provient de :", choices: ["L'expérience sensible", "La raison et les idées innées", "La révélation", "Les habitudes sociales"], answer: 1, note: "Rationalisme : les vérités fondamentales sont connues par la raison seule." },
    { q: "Locke défend :", choices: ["La monarchie absolue", "Les droits naturels (vie, liberté, propriété) et le gouvernement limité", "Le communisme", "La théocratie"], answer: 1, note: "Locke : droits naturels + gouvernement limité + droit de résistance." },
    { q: "Montesquieu préconise dans l'Esprit des Lois :", choices: ["La monarchie absolue", "La séparation des pouvoirs", "La démocratie directe", "La théocratie"], answer: 1, note: "Montesquieu : séparer les pouvoirs exécutif, législatif et judiciaire." },
    { q: "L'éthique déontologique de Kant est fondée sur :", choices: ["Les conséquences des actions", "Le devoir et la loi morale universelle", "Le bonheur collectif", "Les vertus du caractère"], answer: 1, note: "Éthique kantienne : une action est morale si elle est accomplie par devoir." },
    { q: "L'éthique conséquentialiste juge les actions selon :", choices: ["L'intention", "Les conséquences et résultats", "La règle morale", "La vertu de l'agent"], answer: 1, note: "Conséquentialisme : la valeur morale dépend des conséquences." },
    { q: "Sartre est un représentant de :", choices: ["L'empirisme", "L'existentialisme athée", "Le rationalisme", "Le positivisme"], answer: 1, note: "Sartre est le représentant principal de l'existentialisme athée." },
    { q: "Simone de Beauvoir est connue pour :", choices: ["La phénoménologie pure", "Le féminisme existentialiste (Le Deuxième Sexe, 1949)", "L'utilitarisme", "Le pragmatisme"], answer: 1, note: "De Beauvoir : 'On ne naît pas femme, on le devient'." },
    { q: "Camus défend la philosophie de :", choices: ["L'existentialisme sartrien", "L'absurde et la révolte (Le Mythe de Sisyphe)", "L'utilitarisme", "Le marxisme"], answer: 1, note: "Camus (Le Mythe de Sisyphe, 1942) : la vie est absurde → révolte." },
    { q: "John Rawls développe :", choices: ["La justice comme utilité", "La justice comme équité (derrière le voile d'ignorance)", "La justice divine", "La justice des forts"], answer: 1, note: "Rawls (Théorie de la Justice, 1971) : justice derrière le voile d'ignorance." },
    { q: "La métaphysique étudie :", choices: ["Les lois de la nature", "Les questions fondamentales sur l'être, la réalité, le temps", "La logique formelle", "La politique"], answer: 1, note: "La métaphysique = étude de ce qui existe fondamentalement." },
    { q: "L'épistémologie étudie :", choices: ["L'être", "La connaissance et ses fondements", "La politique", "L'esthétique"], answer: 1, note: "Épistémologie = théorie de la connaissance." },
    { q: "La logique déductive part de :", choices: ["Cas particuliers vers une règle générale", "Prémisses générales vers une conclusion particulière nécessaire", "L'expérience sensible", "Les émotions"], answer: 1, note: "Déduction : du général vers le particulier. La conclusion est certaine si les prémisses sont vraies." },
    { q: "La logique inductive part de :", choices: ["Prémisses générales vers particulier", "Cas particuliers vers une conclusion générale probable", "Des axiomes mathématiques", "Des révélations"], answer: 1, note: "Induction : du particulier vers le général. La conclusion est probable." },
    { q: "L'argument cosmologique (Thomas d'Aquin) dit :", choices: ["Dieu est parfait donc existe", "Tout ce qui existe a une cause → première cause non causée = Dieu", "Dieu existe car l'univers est beau", "Dieu existe car nous le sentons"], answer: 1, note: "Argument cosmologique : régression causale → nécessité d'une première cause non causée." },
    { q: "Le libre arbitre s'oppose au :", choices: ["Rationalisme", "Déterminisme (tout est causalement déterminé)", "Empirisme", "Pragmatisme"], answer: 1, note: "Libre arbitre vs déterminisme : peut-on faire autrement que ce que les lois causales déterminent ?" },
    { q: "Le compatibilisme soutient que :", choices: ["Libre arbitre et déterminisme sont incompatibles", "Libre arbitre et déterminisme sont compatibles", "Il n'y a pas de libre arbitre", "Le déterminisme est faux"], answer: 1, note: "Compatibilisme (Hume, Mill) : le libre arbitre est compatible avec le déterminisme." },
    { q: "La philosophie Ubuntu africaine affirme que :", choices: ["L'individu est primordial", "'Je suis parce que nous sommes' (umuntu ngumuntu ngabantu)", "La technologie est la solution", "L'État doit disparaître"], answer: 1, note: "Ubuntu : l'identité d'une personne est liée à la communauté." },
    { q: "La méthode cartésienne comprend :", choices: ["3 règles", "4 règles (évidence, analyse, synthèse, dénombrement)", "7 règles", "1 seule règle"], answer: 1, note: "Descartes (Discours de la méthode) : 4 règles." },
    { q: "Haïti est un haut lieu de philosophie révolutionnaire grâce à :", choices: ["Sa littérature classique", "Sa Révolution de 1804 incarnant les idéaux des Lumières", "Son économie", "Sa géographie"], answer: 1, note: "La Révolution haïtienne (1804) est la seule révolution d'esclaves réussie." },
    { q: "La philosophie de Confucius porte sur :", choices: ["La métaphysique abstraite", "L'éthique sociale, la vertu et les relations humaines harmonieuses", "La logique formelle", "La physique du cosmos"], answer: 1, note: "Confucius (551-479 av.J.-C.) : éthique sociale, rites, humanité (ren)." },
    { q: "Le bouddhisme enseigne que la souffrance vient de :", choices: ["L'ignorance des lois physiques", "Le désir et l'attachement", "La pauvreté uniquement", "La société injuste"], answer: 1, note: "Bouddha : la souffrance (dukkha) est causée par le désir (tanha)." },
    { q: "La philosophie taoïste de Lao-Tseu enseigne :", choices: ["La conquête de la nature", "L'harmonie avec le Tao et le non-agir (wu wei)", "La guerre comme vertu", "L'accumulation de richesses"], answer: 1, note: "Taoïsme : s'aligner avec le Tao via le wu wei (non-agir)." },
    { q: "L'esthétique philosophique étudie :", choices: ["Les lois économiques", "La nature du beau, de l'art et de l'expérience esthétique", "La politique", "La logique"], answer: 1, note: "Esthétique = branche de la philosophie portant sur le beau, le sublime et l'art." },
    { q: "La phénoménologie de Husserl étudie :", choices: ["Les lois naturelles", "L'expérience consciente telle qu'elle se présente", "La structure sociale", "Les institutions politiques"], answer: 1, note: "Husserl : la phénoménologie = étude des structures de la conscience." },
    { q: "Aristote s'oppose à Platon en disant que les formes sont :", choices: ["Dans un monde séparé", "Inhérentes aux choses elles-mêmes", "Dans la pensée divine", "Inexistantes"], answer: 1, note: "Aristote : les formes existent dans les choses (hylemorphisme), pas dans un monde séparé." },
    { q: "Le scepticisme philosophique doute de :", choices: ["L'existence de l'État", "La possibilité de toute connaissance certaine", "L'existence de la matière", "La valeur de la vertu"], answer: 1, note: "Le scepticisme (Pyrrhon) : suspension du jugement (epoché)." },
    { q: "Le principe de réfutabilité de Popper dit :", choices: ["Seules les théories vraies sont scientifiques", "Une théorie est scientifique si elle peut être réfutée", "Les théories vieilles sont meilleures", "Les mathématiques prouvent les théories"], answer: 1, note: "Popper (falsifiabilité) : seules les théories réfutables appartiennent à la science." },
    { q: "Thomas Kuhn parle de :", choices: ["Monades", "Paradigmes et révolutions scientifiques", "Catégories kantiennes", "Idées innées"], answer: 1, note: "Kuhn : la science progresse par révolutions (changements de paradigmes)." },
    { q: "La philosophie de l'éducation de Dewey prône :", choices: ["La mémorisation passive", "L'apprentissage par l'expérience (learning by doing)", "L'obéissance stricte", "L'élitisme intellectuel"], answer: 1, note: "Dewey : l'éducation doit partir de l'expérience de l'enfant." },
    { q: "L'herméneutique (Gadamer) étudie :", choices: ["Les lois physiques", "L'interprétation des textes et la compréhension", "La logique formelle", "Les mathématiques"], answer: 1, note: "Herméneutique : théorie de l'interprétation, du cercle herméneutique." },
    { q: "Wittgenstein II affirme que le sens d'un mot est :", choices: ["Sa référence dans le monde", "Son usage dans la pratique langagière", "Sa définition dans le dictionnaire", "Sa structure logique"], answer: 1, note: "Wittgenstein (Investigations philosophiques) : le sens = l'usage dans les jeux de langage." },
    { q: "L'idéalisme de Berkeley affirme que :", choices: ["La matière est fondamentale", "Esse est percipi (être c'est être perçu)", "L'esprit et la matière coexistent", "La science est la seule vérité"], answer: 1, note: "Berkeley : les objets matériels n'existent que dans la perception." },
    { q: "Hannah Arendt est connue pour :", choices: ["Le structuralisme", "La Condition de l'homme moderne et l'analyse du totalitarisme", "L'utilitarisme", "Le pragmatisme américain"], answer: 1, note: "Arendt : Les Origines du totalitarisme, La Condition de l'homme moderne." },
    { q: "La philosophie politique de Spinoza est souvent qualifiée de :", choices: ["Dualiste", "Panthéiste (Dieu = Nature)", "Agnostique", "Nihiliste"], answer: 1, note: "Spinoza est le principal représentant du panthéisme philosophique." },
    { q: "Leibniz développe la théorie des :", choices: ["Atomes matériels", "Monades (substances simples indivisibles)", "Idées platoniciennes", "Formes aristotéliciennes"], answer: 1, note: "Leibniz : les monades sont des substances simples constituant toute réalité." },
    { q: "La philosophie de Confucius porte principalement sur :", choices: ["La métaphysique abstraite", "L'éthique sociale et les relations humaines harmonieuses", "La logique formelle", "La physique"], answer: 1, note: "Confucius : éthique sociale, rites, humanité (ren), loyauté, piété filiale." },
    { q: "Le bouddhisme philosophique enseigne que la voie de la libération passe par :", choices: ["L'accumulation de richesses", "La méditation et l'abandon du désir", "La guerre sainte", "L'obéissance à l'État"], answer: 1, note: "Le bouddhisme : Quatre Nobles Vérités et Noble Chemin Octuple — voie du milieu." },
    { q: "La philosophie Ubuntu africaine affirme :", choices: ["L'individu est primordial", "'Je suis parce que nous sommes'", "La technologie est la solution", "L'État doit disparaître"], answer: 1, note: "Ubuntu : l'identité d'une personne est liée à la communauté." },
    { q: "L'esthétique de Kant distingue le beau du sublime car :", choices: ["Le beau est plus grand", "Le sublime provoque plaisir + respect/frayeur (face à l'infini)", "Le sublime est artificiel", "Le beau est objectif"], answer: 1, note: "Kant (Critique du jugement) : le beau plaît sans intérêt ; le sublime dépasse les limites sensibles." },
    { q: "Foucault analyse :", choices: ["Les structures du langage uniquement", "Les relations de pouvoir et les discours qui construisent la réalité sociale", "L'économie politique", "La logique formelle"], answer: 1, note: "Foucault : archéologie des savoirs, analyse du pouvoir/savoir (Surveiller et punir)." },
    { q: "Derrida développe la :", choices: ["Phénoménologie", "Déconstruction (remise en question des oppositions binaires)", "Dialectique marxiste", "Phénoménologie transcendantale"], answer: 1, note: "Derrida : la déconstruction défait les oppositions binaires (raison/folie...)." },
