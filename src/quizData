    { q: "La sociologie de Weber est dite :", choices: ["Positiviste", "Compréhensive (Verstehen — comprendre les motivations des acteurs)", "Marxiste", "Structuraliste"], answer: 1, note: "Weber : sociologie compréhensive — comprendre le sens que les acteurs donnent à leurs actions." },
    { q: "Le concept de 'capital culturel' est de :", choices: ["Durkheim", "Pierre Bourdieu", "Marx", "Weber"], answer: 1, note: "Bourdieu : capital culturel = ressources culturelles (diplômes, habitus, goûts) transmises par la famille." },
    { q: "La notion d''anomie' chez Durkheim désigne :", choices: ["Une norme sociale forte", "Un état de dérèglement des normes sociales (absence de régulation)", "Une intégration sociale maximale", "Une conformité totale"], answer: 1, note: "Anomie (Durkheim) : affaiblissement des normes sociales → désorientation, déviance, suicide anomique." },
