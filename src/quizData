    { q: "Camus a reçu le Prix Nobel de Littérature en :", choices: ["1943", "1957", "1964", "1969"], answer: 1, note: "Camus a reçu le Prix Nobel de Littérature en 1957." },
    { q: "Simone de Beauvoir a écrit :", choices: ["L'Être et le Néant", "Le Deuxième Sexe (1949) et Les Mandarins", "La Nausée", "L'Existentialisme est un humanisme"], answer: 1, note: "De Beauvoir : Le Deuxième Sexe — analyse féministe de la condition féminine." },
    { q: "Beckett a écrit :", choices: ["La Cantatrice chauve", "En attendant Godot (1952) et Fin de partie", "Les Chaises", "La Leçon"], answer: 1, note: "Beckett (1906-1989) : En attendant Godot — théâtre de l'absurde. Prix Nobel 1969." },
    { q: "Ionesco est l'auteur de :", choices: ["En attendant Godot", "La Cantatrice chauve (1950) et Les Chaises", "Les Séquestrés d'Altona", "Les Mots"], answer: 1, note: "Ionesco (1909-1994) : fondateur du théâtre de l'absurde." },
    { q: "Corneille est connu pour :", choices: ["La comédie légère", "La tragédie héroïque (Le Cid, Horace, Cinna)", "Le roman pastoral", "La poésie lyrique"], answer: 1, note: "Corneille (1606-1684) : tragédies héroïques — le devoir face aux passions." },
    { q: "La querelle du Cid (1637) porte sur :", choices: ["La morale de la pièce", "Le respect des règles classiques (unités, bienséance)", "Le style de l'auteur", "La distribution des acteurs"], answer: 1, note: "La querelle du Cid : l'Académie critique la pièce de Corneille pour non-respect des règles." },
    { q: "Modiano, Prix Nobel 2014, est connu pour :", choices: ["Ses poèmes surréalistes", "Ses romans sur la mémoire et l'Occupation (Dora Bruder)", "Ses pièces de théâtre", "Ses essais philosophiques"], answer: 1, note: "Modiano (né 1945) : Prix Nobel 2014 — romans sur la mémoire fragmentée, l'Occupation nazie." },
    { q: "Annie Ernaux, Prix Nobel 2022, est connue pour :", choices: ["Ses romans policiers", "Son autosociobiographie (Les Années, La Place, La Honte)", "Ses poèmes symbolistes", "Ses pièces de théâtre"], answer: 1, note: "Annie Ernaux (née 1940) : Prix Nobel 2022 — autosociobiographie, trajectoire de classe." },
    { q: "François Villon est un poète du :", choices: ["Classicisme", "Moyen Âge (XVe siècle)", "Romantisme", "Réalisme"], answer: 1, note: "Villon (1431-v.1463) : poète médiéval, auteur du Testament et de la Ballade des pendus." },
    { q: "La Pléiade (XVIe) est un groupe de :", choices: ["Romanciers naturalistes", "Poètes humanistes (Du Bellay, Ronsard) valorisant le français", "Dramaturges classiques", "Philosophes des Lumières"], answer: 1, note: "La Pléiade : Défense et Illustration de la langue française (1549) — ennoblir le français." },
    { q: "Le classicisme français (XVIIe) valorise :", choices: ["La liberté créatrice totale", "La raison, la mesure, la clarté et les règles", "L'émotion pure", "L'expérimentation formelle"], answer: 1, note: "Classicisme : raison, ordre, harmonie, clarté — l'art doit plaire et instruire." },
    { q: "Mallarmé développe une poésie :", choices: ["Simple et accessible", "Hermétique, visant la Pureté absolue", "Engagée politiquement", "Descriptive et réaliste"], answer: 1, note: "Mallarmé (1842-1898) : poésie hermétique, musicale, aspiration à l'Œuvre absolue." },
    { q: "Le baroque (XVIIe) se caractérise par :", choices: ["La simplicité et la clarté", "Le mouvement, l'exubérance, l'instabilité", "La rigueur classique", "La sobriété morale"], answer: 1, note: "Baroque : instabilité, exagération, métamorphose, illusion (opposé au classicisme)." },
    { q: "Germinal (1885) de Zola décrit :", choices: ["La bourgeoisie parisienne", "La condition des mineurs dans le Nord et leur révolte", "La vie à la cour", "Les paysans de Normandie"], answer: 1, note: "Germinal : grève des mineurs — dénonciation du capitalisme industriel et de l'exploitation." },
    { q: "Le surréalisme libère :", choices: ["La raison et la logique", "L'inconscient, les rêves et l'automatisme psychique", "Les émotions romantiques", "Les règles classiques"], answer: 1, note: "Surréalisme (Breton, 1924) : libérer l'inconscient, l'automatisme, le rêve." },
    { q: "Baudelaire est le fondateur de :", choices: ["Le Romantisme", "Le Symbolisme et la modernité poétique", "Le Naturalisme", "Le Surréalisme"], answer: 1, note: "Baudelaire (Les Fleurs du Mal, 1857) est le père du Symbolisme et de la poésie moderne." },
    { q: "L'Encyclopédie des Lumières visait à :", choices: ["Renforcer la religion", "Répandre les connaissances et lutter contre les préjugés", "Défendre la monarchie", "Promouvoir le colonialisme"], answer: 1, note: "L'Encyclopédie (1751-1772) : diffuser les connaissances, combattre l'obscurantisme." },
    { q: "La Négritude est fondée par :", choices: ["Victor Hugo et Lamartine", "Aimé Césaire, Léopold Sédar Senghor et Léon-Gontran Damas", "André Breton et Aragon", "Sartre et Camus"], answer: 1, note: "Négritude fondée par Césaire (Martinique), Senghor (Sénégal) et Damas (Guyane) dans les années 1930-40." },
    { q: "Le Roman de la Rose est du :", choices: ["XVIe siècle", "XIIIe siècle (Moyen Âge)", "XVIIe siècle", "XIXe siècle"], answer: 1, note: "Le Roman de la Rose (XIIIe siècle) : allégorie médiévale sur l'amour courtois." },
    { q: "Du Bellay a écrit :", choices: ["Les Contemplations", "Les Regrets et Les Antiquités de Rome", "Les Fleurs du Mal", "Alcools"], answer: 1, note: "Du Bellay (1522-1560) : Les Regrets (1558) — sonnets sur l'exil à Rome." },
    { q: "J.M.G. Le Clézio, Prix Nobel 2008, explore :", choices: ["La société bourgeoise française", "Les cultures marginalisées, les migrations et la rencontre des civilisations", "La bourgeoisie provinciale", "L'absurde existentiel"], answer: 1, note: "Le Clézio (né 1940) : Prix Nobel 2008 — auteur de 'Désert', 'Le Chercheur d'or'." },
    { q: "La fable est un genre littéraire qui :", choices: ["Raconte des événements historiques", "Met en scène des animaux ou personnages pour illustrer une morale", "Décrit la nature avec précision", "Est toujours en prose"], answer: 1, note: "La fable : court récit (souvent en vers) avec des personnages symboliques → morale finale." },
    { q: "Le roman épistolaire est un roman composé de :", choices: ["Chapitres chronologiques", "Lettres échangées entre les personnages", "Dialogues uniquement", "Monologues intérieurs"], answer: 1, note: "Roman épistolaire : roman en lettres (ex: Les Liaisons dangereuses de Laclos)." },
    { q: "Le roman à thèse est un roman qui :", choices: ["Décrit uniquement la nature", "Cherche à démontrer une idée ou un système de valeurs", "Est toujours comique", "N'a pas de personnages"], answer: 1, note: "Roman à thèse : roman qui illustre et défend une idée philosophique, morale ou politique." },
    { q: "L'autobiographie est différente de la fiction car :", choices: ["Elle est plus courte", "L'auteur, le narrateur et le personnage principal sont la même personne (pacte autobiographique)", "Elle est anonyme", "Elle n'a pas de structure narrative"], answer: 1, note: "Autobiographie (Lejeune) : identité auteur-narrateur-personnage. L'auteur signe ses expériences réelles." },
    { q: "Le roman picaresque (XVIe-XVIIe) est centré sur :", choices: ["Un héros noble", "Un antihéros (pícaro) aventurier dans une société corrompue", "Un récit historique", "Une histoire d'amour courtois"], answer: 1, note: "Roman picaresque (espagnol) : aventures d'un antihéros gueux (Lazarillo de Tormes) — critique sociale." },
    { q: "Le Parnasse (XIXe) est un mouvement poétique valorisant :", choices: ["L'engagement politique", "La perfection formelle, l'art pour l'art (l'Art pour l'Art)", "L'expression des sentiments", "Le vers libre"], answer: 1, note: "Parnasse (Leconte de Lisle, Heredia, Gautier) : culte de la forme parfaite, impassibilité, beauté froide." },
    { q: "Le vers libre est caractérisé par :", choices: ["Un nombre de syllabes fixe", "L'absence de contraintes métriques régulières", "La rime obligatoire", "Le respect de l'alexandrin"], answer: 1, note: "Vers libre : pas de métrique régulière fixe, liberté rythmique — popularisé par Verlaine et Rimbaud." },
    { q: "L'alexandrin est un vers de :", choices: ["8 syllabes", "10 syllabes", "12 syllabes", "14 syllabes"], answer: 2, note: "L'alexandrin = vers de 12 syllabes, divisé en 2 hémistiches de 6 (le vers héroïque du classicisme)." },
    { q: "La césure dans un alexandrin est :", choices: ["Une faute de versification", "La coupure au milieu du vers (après la 6ème syllabe)", "Un vers incomplet", "Une rime interne"], answer: 1, note: "Césure : pause marquée au milieu du vers classique (alexandrin : coupe après le 6ème pied)." },
    { q: "L'enjambement est :", choices: ["Une figure de style", "Le rejet du sens d'un vers sur le vers suivant (sans pause en fin de vers)", "Une faute grammaticale", "Une métaphore"], answer: 1, note: "Enjambement : la phrase déborde sur le vers suivant, créant un effet de fluidité ou d'accélération." },
    { q: "La métaphore est :", choices: ["Une comparaison avec 'comme'", "Une comparaison sans terme comparatif", "Une répétition", "Un euphémisme"], answer: 1, note: "Métaphore : comparaison implicite sans outil comparatif (ex: 'la vie est un long fleuve tranquille')." },
    { q: "La comparaison est :", choices: ["Une comparaison sans outil", "Une comparaison avec un outil comparatif (comme, tel que, ainsi que...)", "Une répétition", "Une métonymie"], answer: 1, note: "Comparaison : rapprochement de deux termes avec un outil comparatif (ex: 'courageux comme un lion')." },
    { q: "L'allégorie est :", choices: ["Une figure de style d'opposition", "Une représentation concrète d'une idée abstraite par une image ou un récit", "Une répétition à effet", "Un silence expressif"], answer: 1, note: "Allégorie : représentation symbolique prolongée d'une idée abstraite (ex: Justice = femme aux yeux bandés)." },
    { q: "L'ironie est :", choices: ["Dire exactement ce qu'on pense", "Dire le contraire de ce qu'on veut faire comprendre, pour railler", "Une figure de l'émotion", "Une répétition sonore"], answer: 1, note: "Ironie : dire le contraire de sa pensée pour critiquer ou railler (ex: Voltaire dans Candide)." },
    { q: "L'hyperbole est :", choices: ["Une atténuation", "Une exagération dans le but de renforcer l'expression", "Une comparaison", "Un euphémisme"], answer: 1, note: "Hyperbole : exagération expressive (ex: 'Je meurs de faim', 'une mer de larmes')." },
    { q: "La litote est :", choices: ["Une exagération", "Dire moins pour exprimer plus (euphémisme atténuant)", "Une répétition", "Une comparaison directe"], answer: 1, note: "Litote : atténuation expressive (ex: 'Ce n'est pas mauvais' pour dire 'c'est excellent')." },
    { q: "La périphrase est :", choices: ["Un mot simple", "Désigner une chose par une expression plus longue qui la décrit", "Une contraction", "Une métaphore"], answer: 1, note: "Périphrase : remplacer un mot par une description (ex: 'le Roi des animaux' pour 'le lion')." },
    { q: "La synecdoque est :", choices: ["Une figure d'opposition", "Désigner le tout par une partie ou une partie par le tout", "Une figure de répétition", "Une ironie dramatique"], answer: 1, note: "Synecdoque : voile pour désigner un navire (la partie pour le tout), ou l'inverse." },
    { q: "L'anaphore est :", choices: ["Une figure d'opposition", "La répétition d'un mot ou groupe de mots en début de phrases ou de vers successifs", "Une figure de silence", "Une comparaison étendue"], answer: 1, note: "Anaphore : répétition en début de vers/phrase (ex: Hugo 'Et toujours ! Et toujours !')." },
    { q: "Le théâtre de boulevard est :", choices: ["Du théâtre expérimental", "Un théâtre commercial de divertissement léger (vaudeville, comédies)", "Du théâtre d'avant-garde", "Du théâtre classique pur"], answer: 1, note: "Théâtre de boulevard : comédies légères, vaudevilles, spectacles populaires de divertissement." },
    { q: "Le drame bourgeois (Diderot) est :", choices: ["Un genre tragique", "Un genre intermédiaire entre comédie et tragédie, centré sur la vie bourgeoise", "Un opéra", "Un roman dialogué"], answer: 1, note: "Drame bourgeois (Diderot, Sedaine) : genre intermédiaire, personnages et sujets de la vie quotidienne." },
    { q: "La tragi-comédie est :", choices: ["Une comédie musicale", "Un genre mélangeant les registres tragique et comique", "Un opéra tragique", "Un roman épique"], answer: 1, note: "Tragi-comédie : genre du XVIIe mélangeant le tragique et le comique, avant la séparation classique stricte." },
    { q: "Le roman de formation (Bildungsroman) est :", choices: ["Un roman historique", "Un roman centré sur la formation d'un jeune protagoniste", "Un roman d'amour", "Un roman policier"], answer: 1, note: "Bildungsroman : roman d'apprentissage — le héros grandit et se forme (ex: Wilhelm Meister, Goethe)." },
    { q: "La nouvelle est différente du roman par :", choices: ["Son style", "Sa longueur (plus brève) et sa concentration sur un épisode ou une situation unique", "Son manque de personnages", "Son absence de dialogue"], answer: 1, note: "La nouvelle : récit bref concentré sur un épisode unique (ex: Maupassant, Boule de Suif)." },
    { q: "Le conte philosophique (Voltaire) est :", choices: ["Un conte pour enfants", "Une fiction allégorique illustrant des idées philosophiques", "Un récit historique", "Une autobiographie"], answer: 1, note: "Conte philosophique : fiction illustrant des idées des Lumières (Candide, Micromégas, Zadig)." },
    { q: "La prose poétique est :", choices: ["Une poésie en vers", "Un texte en prose qui utilise des techniques poétiques (rythme, images, musicalité)", "Une prose ordinaire", "Un mélange de vers et de prose"], answer: 1, note: "Prose poétique : texte en prose au style proche de la poésie (ex: Baudelaire, Le Spleen de Paris)." },
    { q: "Patrick Chamoiseau est un auteur martiniquais-français connu pour :", choices: ["L'indigénisme", "Texaco (Prix Goncourt 1992) et son œuvre créoliste", "Le surréalisme", "Le naturalisme"], answer: 1, note: "Chamoiseau (né 1953) : Texaco (Goncourt 1992) — créolité, mémoire des esclaves, Martinique." },
    { q: "La littérature de l'exil (ou de la migration) explore :", choices: ["Uniquement les pays d'accueil", "La douleur du déracinement, la nostalgie et la construction identitaire entre deux cultures", "La politique internationale uniquement", "L'histoire coloniale uniquement"], answer: 1, note: "Littérature de la migration : entre-deux culturel, déracinement, reconstruction identitaire." },
    { q: "Marguerite Yourcenar est connue pour :", choices: ["Ses poèmes symbolistes", "Les Mémoires d'Hadrien (1951) — première femme à l'Académie française (1980)", "Ses pièces de théâtre absurde", "Ses nouvelles naturalistes"], answer: 1, note: "Yourcenar (1903-1987) : première femme élue à l'Académie française en 1980." },
    { q: "Le Nouveau Roman (Robbe-Grillet, Sarraute) de la décennie 1950-60 :", choices: ["Imite les formes classiques", "Déconstruit les conventions du roman traditionnel (personnages, intrigue, chronologie)", "Valorise l'engagement politique", "Adopte le réalisme photographique"], answer: 1, note: "Nouveau Roman : refus du personnage, de l'intrigue et du narrateur traditionnel — écriture expérimentale." },
    { q: "La notion de 'voix narrative' désigne :", choices: ["La voix de l'auteur dans la vie réelle", "La perspective et la position du narrateur dans le récit", "Le ton général de l'œuvre", "Les dialogues des personnages"], answer: 1, note: "Voix narrative : qui parle dans le récit ? (narrateur omniscient, personnage, narrateur externe...)" },
    { q: "La focalisation interne dans un récit signifie que :", choices: ["Le narrateur sait tout", "Le lecteur voit le monde à travers un seul personnage", "Il y a plusieurs narrateurs", "L'histoire est racontée de l'extérieur"], answer: 1, note: "Focalisation interne : le récit est limité à la perspective d'un personnage (on ne sait que ce qu'il sait)." },
    { q: "Le réalisme socialiste soviétique prônait :", choices: ["L'art pour l'art", "L'art au service du progrès socialiste, accessible et optimiste", "L'expérimentation formelle", "L'art mystique"], answer: 1, note: "Réalisme socialiste (Zhdanov) : l'art doit être 'réaliste dans sa forme, socialiste dans son contenu'." },
    { q: "La littérature francophone africaine (Achebe, Senghor, Sembène) explore :", choices: ["L'exaltation du colonialisme", "L'identité africaine, la décolonisation et la condition postcoloniale", "La science-fiction", "La philosophie classique"], answer: 1, note: "Littérature francophone africaine : identité, négritude, décolonisation, postcolonialisme." },
  ],
