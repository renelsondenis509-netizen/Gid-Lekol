  "Physique": [
    { q: "Le 2ème principe de Newton s'écrit :", choices: ["F=mv", "F=ma", "F=m/a", "F=m²a"], answer: 1, note: "ΣF = ma : résultante des forces = masse × accélération." },
    { q: "Un corps en chute libre en 2s (g=10m/s²) parcourt :", choices: ["10 m", "20 m", "40 m", "5 m"], answer: 1, note: "h = ½gt² = ½×10×4 = 20 m" },
    { q: "La loi de gravitation universelle est :", choices: ["F=Gm₁m₂d²", "F=Gm₁m₂/d²", "F=G(m₁+m₂)/d", "F=Gm₁/(m₂d)"], answer: 1, note: "F = Gm₁m₂/d² où G = 6,67×10⁻¹¹ N·m²/kg²." },
    { q: "Dans un circuit série, la résistance équivalente est :", choices: ["R₁×R₂", "R₁+R₂", "R₁R₂/(R₁+R₂)", "R₁-R₂"], answer: 1, note: "En série : Réq = R₁+R₂+...+Rn" },
    { q: "La loi de Snell-Descartes s'écrit :", choices: ["n₁cosθ₁=n₂cosθ₂", "n₁sinθ₁=n₂sinθ₂", "n₁/sinθ₁=n₂/sinθ₂", "n₁tanθ₁=n₂tanθ₂"], answer: 1, note: "Réfraction : n₁sinθ₁ = n₂sinθ₂." },
    { q: "L'énergie cinétique est :", choices: ["Ec=mv", "Ec=mv²", "Ec=½mv²", "Ec=½mv"], answer: 2, note: "Ec = ½mv² (Joules)." },
    { q: "La dilatation thermique linéaire est :", choices: ["ΔL=L₀αΔT²", "ΔL=L₀αΔT", "ΔL=L₀/(αΔT)", "ΔL=α/(L₀ΔT)"], answer: 1, note: "ΔL = L₀αΔT où α est le coefficient de dilatation linéaire." },
    { q: "La fréquence et la période sont liées par :", choices: ["f=T", "f=T²", "f=1/T", "f=2πT"], answer: 2, note: "f = 1/T (Hz = 1/s)." },
    { q: "La conservation de l'énergie mécanique s'applique quand :", choices: ["Il y a des frottements", "Les forces non conservatives sont nulles", "La vitesse est constante", "La masse varie"], answer: 1, note: "Em = Ec+Ep = constante en absence de forces dissipatives." },
    { q: "L'énergie stockée dans un condensateur C sous tension U est :", choices: ["E=CU", "E=½CU²", "E=C²U", "E=CU²"], answer: 1, note: "E = ½CU² (Joules)." },
    { q: "Le 1er principe de Newton (inertie) dit qu'un objet sans force :", choices: ["Accélère", "Reste en repos ou en MRU", "Tourne", "Ralentit toujours"], answer: 1, note: "Sans force résultante, un corps reste au repos ou en mouvement rectiligne uniforme." },
    { q: "Le 3ème principe de Newton dit :", choices: ["Une force est toujours verticale", "Toute action a une réaction égale et opposée", "La masse est proportionnelle à la force", "L'accélération dépend du volume"], answer: 1, note: "3ème loi : si A exerce F sur B, alors B exerce -F sur A." },
    { q: "La quantité de mouvement p est :", choices: ["p=m/v", "p=mv", "p=m+v", "p=mv²"], answer: 1, note: "Quantité de mouvement p = mv (kg·m/s)." },
    { q: "Le travail d'une force est :", choices: ["W=F/d", "W=Fd", "W=Fdcosα", "W=Fd²"], answer: 2, note: "W = F·d·cosα où α est l'angle entre F et le déplacement." },
    { q: "La puissance est définie par :", choices: ["P=Wt", "P=W/t", "P=W+t", "P=W²/t"], answer: 1, note: "P = W/t (Watts = Joules/seconde)." },
    { q: "L'énergie potentielle de pesanteur est :", choices: ["Ep=mv", "Ep=mgh", "Ep=½mv²", "Ep=mgh²"], answer: 1, note: "Ep = mgh où m=masse, g=9,8m/s², h=hauteur." },
    { q: "La vitesse en MRUA est :", choices: ["v=v₀+a/t", "v=v₀+at", "v=v₀at", "v=v₀-at²"], answer: 1, note: "MRUA : v = v₀ + at." },
    { q: "La distance en MRUA est :", choices: ["d=v₀t", "d=v₀t+½at²", "d=at²", "d=½at"], answer: 1, note: "MRUA : d = v₀t + ½at²." },
    { q: "La loi d'Ohm s'exprime par :", choices: ["U=R/I", "U=RI", "U=R+I", "U=R-I"], answer: 1, note: "Loi d'Ohm : U = RI." },
    { q: "Dans un circuit parallèle, la tension aux bornes des résistances est :", choices: ["Différente pour chaque R", "La même pour toutes", "Nulle", "Proportionnelle à R"], answer: 1, note: "En parallèle, toutes les résistances sont soumises à la même tension." },
    { q: "La loi des nœuds dit que :", choices: ["La somme des tensions est nulle", "La somme des courants entrants = courants sortants", "Les R s'additionnent", "La tension se divise"], answer: 1, note: "Loi des nœuds (Kirchhoff) : ΣI_entrants = ΣI_sortants." },
    { q: "La loi des mailles dit que :", choices: ["La somme des courants est nulle", "La somme algébrique des tensions dans une maille est nulle", "Les R se multiplient", "Les courants sont égaux"], answer: 1, note: "Loi des mailles (Kirchhoff) : somme algébrique des tensions dans une maille fermée = 0." },
    { q: "La résistance équivalente en parallèle est :", choices: ["R₁+R₂", "R₁R₂/(R₁+R₂)", "R₁-R₂", "(R₁+R₂)/2"], answer: 1, note: "En parallèle : Réq = R₁R₂/(R₁+R₂)." },
    { q: "L'effet Joule (puissance dissipée) est :", choices: ["P=U²/R", "P=RI²", "P=R/I", "P=UI/R"], answer: 1, note: "Puissance dissipée par effet Joule : P = RI² = U²/R = UI." },
    { q: "La vitesse de la lumière dans le vide est :", choices: ["c=3×10⁶ m/s", "c=3×10⁸ m/s", "c=3×10¹⁰ m/s", "c=3×10⁴ m/s"], answer: 1, note: "c = 3×10⁸ m/s = 300 000 km/s dans le vide." },
    { q: "L'indice de réfraction est :", choices: ["n=v/c", "n=c/v", "n=c×v", "n=1/(c×v)"], answer: 1, note: "n = c/v où c = vitesse lumière dans le vide, v = vitesse dans le milieu." },
    { q: "Une lentille convergente a une distance focale :", choices: ["Négative", "Positive", "Nulle", "Infinie"], answer: 1, note: "Les lentilles convergentes ont f > 0 (foyer réel)." },
    { q: "La longueur d'onde λ et la fréquence f sont liées par :", choices: ["λ=f/v", "λ=v/f", "λ=vf", "λ=v-f"], answer: 1, note: "λ = v/f où v est la vitesse de propagation." },
    { q: "Le son se propage :", choices: ["Dans le vide uniquement", "Dans tous les milieux sauf le vide", "Uniquement dans l'air", "Uniquement dans les solides"], answer: 1, note: "Le son est une onde mécanique : il ne se propage pas dans le vide." },
    { q: "L'effet Doppler se manifeste quand :", choices: ["L'amplitude d'une onde change", "La fréquence perçue change avec le mouvement source/observateur", "La vitesse de l'onde augmente", "La longueur d'onde s'annule"], answer: 1, note: "Effet Doppler : la fréquence perçue est modifiée quand source ou observateur est en mouvement." },
    { q: "Le 1er principe de thermodynamique est :", choices: ["L'entropie augmente toujours", "ΔU = Q + W (conservation de l'énergie)", "La chaleur va du chaud vers le froid", "L'énergie disparaît lors des frictions"], answer: 1, note: "1er principe : ΔU = Q + W (énergie reçue sous forme de chaleur + travail)." },
    { q: "Le 2ème principe de thermodynamique énonce :", choices: ["L'énergie se conserve", "L'entropie d'un système isolé ne peut qu'augmenter", "La chaleur va spontanément du froid vers le chaud", "Le travail égale la chaleur"], answer: 1, note: "2ème principe : l'entropie d'un système isolé augmente toujours." },
    { q: "La chaleur Q et la chaleur massique c sont liées par :", choices: ["Q=mc", "Q=mcΔT", "Q=m/cΔT", "Q=c/mΔT"], answer: 1, note: "Q = mcΔT où m=masse, c=chaleur massique, ΔT=variation de température." },
    { q: "La loi de Boyle-Mariotte (T constante) est :", choices: ["PV=nRT", "PV=constante", "P/T=constante", "V/T=constante"], answer: 1, note: "Boyle-Mariotte : à T constante, PV = constante (P₁V₁ = P₂V₂)." },
    { q: "La loi des gaz parfaits est :", choices: ["PV=nRT", "PV=NkT", "Les deux sont correctes", "P/T=constante"], answer: 2, note: "PV = nRT (n=moles, R=8,314 J/mol/K)." },
    { q: "Le zéro absolu correspond à :", choices: ["0°C", "-100°C", "-273,15°C", "-373,15°C"], answer: 2, note: "0 K = -273,15°C est la température minimale théorique." },
    { q: "La pression atmosphérique au niveau de la mer est :", choices: ["10⁵ Pa", "10³ Pa", "10⁷ Pa", "10 Pa"], answer: 0, note: "P₀ = 1 atm ≈ 10⁵ Pa." },
    { q: "La loi de Charles (P constante) est :", choices: ["PV=constante", "V/T=constante", "P/T=constante", "PT=constante"], answer: 1, note: "Loi de Charles : à P constante, V/T = constante." },
    { q: "La loi de Gay-Lussac (V constant) est :", choices: ["PV=constante", "V/T=constante", "P/T=constante", "PT=constante"], answer: 2, note: "Loi de Gay-Lussac : à V constant, P/T = constante." },
    { q: "Le principe d'Archimède : la poussée est égale à :", choices: ["Le poids de l'objet", "Le poids du fluide déplacé", "La masse volumique × volume", "La surface immergée × pression"], answer: 1, note: "Poussée d'Archimède = poids du fluide déplacé = ρ_fluide × V_immergé × g." },
    { q: "La radioactivité alpha émet :", choices: ["Des électrons", "Des noyaux d'hélium (⁴₂He)", "Des photons gamma", "Des neutrons"], answer: 1, note: "La radioactivité α émet des noyaux d'hélium ⁴₂He (2p + 2n)." },
    { q: "La radioactivité bêta moins (β⁻) émet :", choices: ["Des protons", "Des électrons (e⁻)", "Des neutrons", "Des positons"], answer: 1, note: "Radioactivité β⁻ : n → p + e⁻ + ν̄." },
    { q: "La demi-vie (t½) est :", choices: ["Le temps pour désintégrer entièrement", "Le temps pour réduire de moitié la quantité de noyaux", "La période de stabilité", "La moitié de la vie de l'atome"], answer: 1, note: "t½ = temps pour que la moitié des noyaux radioactifs se désintègrent." },
    { q: "La fission nucléaire est :", choices: ["L'union de deux noyaux légers", "La division d'un noyau lourd en noyaux plus légers", "La radioactivité gamma", "L'émission d'électrons"], answer: 1, note: "Fission : un noyau lourd (ex: U-235) se divise en noyaux plus légers + neutrons + énergie." },
    { q: "L'énergie nucléaire vient de :", choices: ["La combustion chimique", "Le défaut de masse (E=mc²)", "La friction atomique", "La polarisation électrique"], answer: 1, note: "E = mc² (Einstein) : la perte de masse est convertie en énergie." },
    { q: "Le théorème de Bernoulli est :", choices: ["La pression est constante", "P+½ρv²+ρgh=constante", "La vitesse est constante", "P=ρgh uniquement"], answer: 1, note: "Bernoulli : P + ½ρv² + ρgh = constante (conservation de l'énergie dans un fluide)." },
    { q: "L'équation de continuité (fluide incompressible) est :", choices: ["P+½ρv²=constante", "S₁v₁=S₂v₂", "ρgh=constante", "F=ΔPS"], answer: 1, note: "Equation de continuité : S₁v₁ = S₂v₂ (conservation du débit)." },
    { q: "La pression hydrostatique augmente avec :", choices: ["La température", "La profondeur", "La vitesse d'écoulement", "La viscosité"], answer: 1, note: "P = P₀ + ρgh : la pression augmente avec la profondeur h." },
    { q: "Le rendement maximum d'une machine thermique (Carnot) est :", choices: ["η=1", "η=1-Tf/Tc", "η=Tf/Tc", "η=(Tc-Tf)/Tf"], answer: 1, note: "Rendement de Carnot : η = 1 - Tf/Tc (températures en Kelvin)." },
    { q: "La loi de Coulomb est :", choices: ["F=kq₁q₂/d", "F=kq₁q₂/d²", "F=kd²/(q₁q₂)", "F=k(q₁+q₂)/d"], answer: 1, note: "Force électrostatique : F = kq₁q₂/d² (analogue à la gravitation)." },
    { q: "La f.é.m. d'un générateur est :", choices: ["La résistance interne", "L'énergie fournie par unité de charge", "La puissance dissipée", "L'intensité maximale"], answer: 1, note: "La f.é.m. ε est l'énergie fournie par le générateur par unité de charge (Volts)." },
    { q: "La tension aux bornes d'un générateur (résistance interne r) est :", choices: ["U=ε+rI", "U=ε-rI", "U=ε/r", "U=ε×r×I"], answer: 1, note: "U = ε - rI (chute de tension interne rI)." },
    { q: "La valeur efficace Ueff d'une tension sinusoïdale Umax est :", choices: ["Ueff=Umax", "Ueff=Umax/2", "Ueff=Umax/√2", "Ueff=√2×Umax"], answer: 2, note: "Ueff = Umax/√2 ≈ 0,707×Umax." },
    { q: "Un transformateur fonctionne avec :", choices: ["Courant continu uniquement", "Courant alternatif uniquement", "Les deux types", "Courant impulsionnel"], answer: 1, note: "Le transformateur fonctionne en courant alternatif (induction électromagnétique)." },
    { q: "La relation de transformation est :", choices: ["U₁/U₂=N₂/N₁", "U₁/U₂=N₁/N₂", "U₁×N₁=U₂×N₂", "U₁+U₂=N₁+N₂"], answer: 1, note: "U₁/U₂ = N₁/N₂ (rapport tensions = rapport spires)." },
    { q: "La loi de Faraday donne la f.é.m. induite :", choices: ["ε=B×l×v", "ε=-dΦ/dt", "ε=B²×l", "ε=Φ/t"], answer: 1, note: "Faraday : ε = -dΦ/dt (f.é.m. induite proportionnelle à la variation du flux)." },
    { q: "La loi de Lenz indique que le courant induit :", choices: ["Amplifie la variation de flux", "S'oppose à la variation de flux qui le crée", "Est toujours nul", "A la même direction que le flux"], answer: 1, note: "Lenz : le courant induit s'oppose à la cause qui le produit." },
    { q: "Le flux magnétique Φ est :", choices: ["Φ=B/S", "Φ=B×S×cosα", "Φ=B+S", "Φ=B×S²"], answer: 1, note: "Φ = B·S·cosα (Wb = Tesla × m²)." },
    { q: "La force de Lorentz sur une charge q dans un champ B est :", choices: ["F=qE", "F=qvBsinθ", "F=mv/B", "F=qB/v"], answer: 1, note: "Force de Lorentz magnétique : F = qvBsinθ." },
    { q: "L'énergie d'un photon est :", choices: ["E=mc²", "E=hf", "E=½mv²", "E=hλ"], answer: 1, note: "E = hf = hc/λ où h = constante de Planck." },
    { q: "La constante de Planck h est :", choices: ["6,67×10⁻¹¹ J·s", "6,63×10⁻³⁴ J·s", "9,11×10⁻³¹ J·s", "1,6×10⁻¹⁹ J·s"], answer: 1, note: "h = 6,63×10⁻³⁴ J·s (constante de Planck)." },
    { q: "La dualité onde-corpuscule de De Broglie : λ = :", choices: ["h/mv", "mv/h", "hv/m", "h×m×v"], answer: 0, note: "Relation de De Broglie : λ = h/(mv) = h/p." },
    { q: "La masse d'un proton est :", choices: ["9,11×10⁻³¹ kg", "1,67×10⁻²⁷ kg", "1,6×10⁻¹⁹ kg", "6,02×10²³ kg"], answer: 1, note: "Masse du proton : mp ≈ 1,67×10⁻²⁷ kg." },
    { q: "La charge élémentaire e est :", choices: ["9,11×10⁻³¹ C", "1,6×10⁻¹⁹ C", "6,67×10⁻¹¹ C", "1,67×10⁻²⁷ C"], answer: 1, note: "e = 1,6×10⁻¹⁹ C (charge du proton)." },
    { q: "La réflexion totale interne se produit quand :", choices: ["L'angle d'incidence est nul", "L'angle d'incidence dépasse l'angle critique", "Le milieu est transparent", "La lumière est polarisée"], answer: 1, note: "Réflexion totale interne : θ > θc (angle limite de réfraction = 90°)." },
    { q: "Un miroir plan forme une image :", choices: ["Réelle et renversée", "Virtuelle et droite, symétrique par rapport au miroir", "Réelle et droite", "Toujours agrandie"], answer: 1, note: "Miroir plan : image virtuelle, droite, même taille, symétrique." },
    { q: "La dispersion de la lumière blanche par un prisme montre que :", choices: ["La lumière blanche est monochromatique", "Elle est composée de toutes les couleurs du spectre", "Le prisme crée les couleurs", "Toutes les λ sont identiques"], answer: 1, note: "La dispersion révèle que la lumière blanche = superposition de toutes les couleurs (400-700 nm)." },
    { q: "Le spectre visible va de :", choices: ["100 à 400 nm", "400 à 700 nm", "700 à 1000 nm", "10 à 100 nm"], answer: 1, note: "Spectre visible : violet (400nm) → rouge (700nm). UV en dessous, IR au-dessus." },
    { q: "La vitesse angulaire ω et la fréquence f sont liées par :", choices: ["ω=f", "ω=2πf", "ω=f/2π", "ω=f²"], answer: 1, note: "ω = 2πf (rad/s)." },
    { q: "Le principe d'incertitude de Heisenberg dit :", choices: ["On peut mesurer exactement position et vitesse", "ΔxΔp ≥ h/(4π) : on ne peut pas mesurer position et quantité de mouvement avec précision infinie", "L'énergie est toujours conservée", "La masse augmente avec la vitesse"], answer: 1, note: "Heisenberg : Δx·Δp ≥ ℏ/2 — incertitude fondamentale sur position et quantité de mouvement." },
    { q: "La relativité restreinte postule que :", choices: ["La vitesse de la lumière dépend de l'observateur", "La vitesse de la lumière est constante pour tous les observateurs inertiels", "La masse est constante", "Le temps est absolu"], answer: 1, note: "Postulat de relativité restreinte : c est la même pour tous les observateurs inertiels." },
    { q: "La contraction des longueurs dit qu'un objet en mouvement :", choices: ["Paraît plus long", "Paraît plus court dans la direction du mouvement", "N'est pas affecté", "Paraît plus large"], answer: 1, note: "Contraction de Lorentz : L = L₀/γ." },
    { q: "L'interférence constructive se produit quand :", choices: ["Les amplitudes sont opposées", "Les ondes sont en phase (ΔΦ=0, 2π, 4π...)", "Les fréquences sont différentes", "L'une des ondes est absorbée"], answer: 1, note: "Interférence constructive : ondes en phase → amplitude maximale." },
    { q: "La diffraction est le phénomène par lequel :", choices: ["La lumière change de vitesse", "Les ondes contournent les obstacles", "La lumière se réfléchit", "Les ondes s'absorbent"], answer: 1, note: "Diffraction : les ondes se courbent autour des obstacles." },
    { q: "La fréquence de résonance d'un circuit LC est :", choices: ["f=2π/√(LC)", "f=1/(2π√(LC))", "f=√(LC)/2π", "f=LC/2π"], answer: 1, note: "Fréquence de résonance : f₀ = 1/(2π√(LC))." },
    { q: "L'impulsion d'une force est :", choices: ["F×d", "F×t", "F/t", "F+t"], answer: 1, note: "Impulsion J = F·Δt = Δp (variation de quantité de mouvement)." },
    { q: "La gravitation crée une accélération de chute libre g de :", choices: ["10 m/s² sur Terre (approximation)", "10 m/s² sur la Lune", "100 m/s² sur Terre", "1 m/s² sur Terre"], answer: 0, note: "g ≈ 9,81 m/s² sur Terre (≈ 10 m/s² en première approximation)." },
    { q: "L'unité de mesure de la force est :", choices: ["Le Joule", "Le Newton", "Le Watt", "Le Pascal"], answer: 1, note: "La force se mesure en Newtons (N = kg·m/s²)." },
    { q: "Le joule est l'unité de :", choices: ["La force", "L'énergie et du travail", "La puissance", "La pression"], answer: 1, note: "Le Joule (J) est l'unité d'énergie et de travail (1 J = 1 N·m = 1 kg·m²/s²)." },
